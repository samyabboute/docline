{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "docline-beta",
  "compatibility_date": "2026-05-15",
  "main": "worker.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "src/pages",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
