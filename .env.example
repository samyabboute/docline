# ============================================================
# PROSPEO — Environment Variables Template
# INSTRUCTIONS: Copy this file to .env — NEVER commit .env
# Set all these as Supabase Edge Function secrets too.
# See DEPLOY.md Part 4.3 for the full command list.
# ============================================================

# ── SUPABASE ────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...         # Public key — safe in frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci... # SECRET — Edge Functions only, NEVER frontend

# ── STRIPE ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...          # SECRET — Edge Functions only
STRIPE_PUBLISHABLE_KEY=pk_live_...     # Public key — safe in frontend
STRIPE_WEBHOOK_SECRET=whsec_...        # From Stripe webhook setup
STRIPE_PRICE_PRO_MONTHLY=price_...     # Price ID from Stripe Products
STRIPE_PRICE_PRO_YEARLY=price_...

# ── RESEND ──────────────────────────────────────────────────
RESEND_API_KEY=re_...                  # SECRET — Edge Functions only

# ── APP ─────────────────────────────────────────────────────
APP_URL=https://app.prospeo.eu
ALLOWED_ORIGIN=https://app.prospeo.eu

# ── ADMIN ───────────────────────────────────────────────────
ADMIN_USER_IDS=your-supabase-user-uuid-here
# Multiple admins: ADMIN_USER_IDS=uuid1,uuid2,uuid3

# ── AUTOMATION ENGINE ────────────────────────────────────────
# Strong random secret to protect the automation-engine endpoint
# Generate: openssl rand -hex 32
AUTOMATION_SECRET=replace-with-a-strong-random-secret
